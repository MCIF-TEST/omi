# Copy this to apps/api/.env and fill in. Never commit .env.

# ---- Core ----
OMI_ENV=development
OMI_LOG_LEVEL=INFO

# Local SQLite by default; in production use Postgres (Supabase / Render):
#   OMI_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/omi
OMI_DATABASE_URL=sqlite:///./data/omi.db

# ---- YouTube ingestion (required for scans) ----
# https://console.cloud.google.com/apis/credentials -> enable YouTube Data API v3
OMI_YOUTUBE_API_KEY=

# Scan caps
OMI_SCAN_MAX_COMMENTERS=150
OMI_SCAN_MAX_HISTORY_PER_COMMENTER=50
OMI_SCAN_CACHE_TTL_DAYS=7

# ---- Public-launch settings ----
# Set true to require login + credits on scan routes (false = local solo mode)
OMI_REQUIRE_AUTH=false

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
OMI_SESSION_SECRET=dev-only-change-me-12345678901234567890

# Public URL of the web app (no trailing slash). Used for Stripe redirects.
OMI_PUBLIC_BASE_URL=http://localhost:3000

# ---- Stripe ----
OMI_STRIPE_SECRET_KEY=
OMI_STRIPE_WEBHOOK_SECRET=
OMI_STRIPE_PRICE_ID=

# Credit grants
OMI_FREE_TRIAL_CREDITS=3
OMI_MONTHLY_CREDIT_GRANT=20

# ---- Embeddings (local, no key needed) ----
OMI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- LLM enhancement (optional — Phase 7) ----
# When set, /v1/investigations/{slug}/commentary uses Claude Haiku to
# generate analyst-style prose. When unset, falls back to a deterministic
# template provider — the product is fully functional either way.
OMI_ANTHROPIC_API_KEY=
OMI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OMI_REASONING_MAX_TOKENS=320

# ---- Monitoring (optional — Phase 8) ----
# Enable the background scheduler that runs anomaly detection + watchlist
# auto-rescans. Off in dev so tests + quiet local installs don't run
# background work; flip to true in production.
OMI_ENABLE_MONITORING=false
OMI_MONITORING_INTERVAL_SECONDS=300
OMI_WATCHLIST_RECHECK_HOURS=6
OMI_WATCHLIST_MAX_PER_TICK=5

# ---- Alert delivery (optional) ----
# SMTP credentials for email-delivered watchlist alerts. Webhook delivery
# works without SMTP; this only governs the email channel.
#
# Recommended providers (any will do, just need standard SMTP creds):
#   * Resend   — smtp.resend.com:465 (TLS), user="resend", pass=re_xxx api key
#   * AWS SES  — email-smtp.us-east-1.amazonaws.com:587 (STARTTLS)
#   * Postmark — smtp.postmarkapp.com:587 (STARTTLS)
#
# After configuring, verify by signing in as an admin and POSTing to
# /v1/monitoring/test-alert — that sends a test alert through both
# email and webhook channels and reports the delivery status of each.
OMI_SMTP_HOST=
OMI_SMTP_PORT=587
OMI_SMTP_USER=
OMI_SMTP_PASSWORD=
OMI_SMTP_FROM=alerts@yourdomain.com
OMI_SMTP_USE_TLS=true

# ---- YouTube quota (operations) ----
# Daily quota cap for the YouTube Data API v3 key. Used for the
# service-health pill that warns at 80% / 95% usage. Default is the
# free-tier limit; raise this if Google has granted you more.
OMI_YOUTUBE_DAILY_QUOTA=10000
